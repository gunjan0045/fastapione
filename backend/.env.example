# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# Database
DATABASE_URL=sqlite:///./sql_app.db

# JWT Secret
SECRET_KEY=your-super-secret-key-change-in-production

# Server
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173


# OAuth (Google/GitHub)
# Create OAuth apps and set callback URLs to:
# http://localhost:8000/auth/oauth/google/callback
# http://localhost:8000/auth/oauth/github/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# SMTP Email Configuration
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# For Mailtrap: use sandbox host and credentials from your inbox settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
# Optional: visible sender in user inbox
SMTP_SENDER=AI Interview Coach <your-email@example.com>
# Optional flags
SMTP_USE_TLS=true
SMTP_USE_SSL=false